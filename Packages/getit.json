{
  "$schema": "https://docwiki.embarcadero.com/RADStudio/getit-package.json",
  "name": "DelphiOBD",
  "displayName": "ERDesigns OBD Framework",
  "description": "Comprehensive OBD-II diagnostics framework for Delphi: gauges, charts, terminal, BLE/serial/Bluetooth/WiFi/FTDI/DoIP transports, ELM327/OBDLink/J2534 adapters, full SAE J1979 service stack (modes 01–0A), KWP2000/UDS/J1939/FlexRay/LIN/MOST protocols, 42 brand radio code calculators, VIN decoder, Skia-rendered touch-friendly components, async future/promise API, structured logging, .obdlog record/replay.",
  "version": "2.3.0",
  "author": "Ernst Reidinga (ERDesigns)",
  "homepage": "https://github.com/erdesigns-eu/Delphi-OBD",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE.md",
  "keywords": [
    "obd", "obd-ii", "obdii", "j1979", "automotive", "diagnostics",
    "elm327", "obdlink", "kwp2000", "uds", "doip", "j1939", "flexray",
    "lin", "most", "vin", "radiocode", "ble", "skia", "vcl", "components"
  ],
  "platforms": ["Win32", "Win64"],
  "ides": ["11", "12"],
  "category": "Components",
  "type": "library",
  "subType": "open-source",

  "designtimePackage": "Packages/DesignTime.dproj",
  "runtimePackage": "Packages/RunTime.dproj",

  "documentation": {
    "readme": "README.md",
    "changelog": "CHANGELOG.md",
    "roadmap": "docs/ROADMAP.md",
    "componentAuthoring": "docs/COMPONENT_AUTHORING.md"
  },

  "examples": [
    { "name": "minimal",   "path": "examples/minimal" },
    { "name": "simple",    "path": "examples/simple" },
    { "name": "dashboard", "path": "examples/dashboard" },
    { "name": "replay",    "path": "examples/replay" },
    { "name": "serial",    "path": "examples/serial" },
    { "name": "bluetooth", "path": "examples/bluetooth" },
    { "name": "wifi",      "path": "examples/wifi" },
    { "name": "ftdi",      "path": "examples/ftdi" },
    { "name": "doip",      "path": "examples/doip" },
    { "name": "kwp2000",   "path": "examples/kwp2000" },
    { "name": "uds",       "path": "examples/uds" },
    { "name": "lin",       "path": "examples/lin" },
    { "name": "flexray",   "path": "examples/flexray" },
    { "name": "most",      "path": "examples/most" },
    { "name": "tachograph","path": "examples/tachograph" },
    { "name": "ecuflashing","path": "examples/ecuflashing" },
    { "name": "advanced",  "path": "examples/advanced" }
  ]
}

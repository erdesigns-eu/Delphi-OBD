#-------------------------------------------------------------------------------
#  .gitignore — Delphi-OBD
#
#  RAD Studio per-developer / per-version artefacts and build outputs are
#  not committed. The .dpk / .dpr source files ARE committed; the .dproj
#  XML files are NOT (RAD Studio regenerates them on first open).
#-------------------------------------------------------------------------------

# RAD Studio project files (regenerated per developer / per version)
*.dproj
*.groupproj
*.identcache
*.local
*.projdata
*.tvsconfig
*.skincfg
__history/
__recovery/

# Build outputs
Win32/
Win64/
OSX64/
Android/
Android64/
iOSDevice32/
iOSDevice64/
iOSSimulator/
Linux64/
*.dcu
*.dcp
*.dcpil
*.bpl
*.exe
*.dll
*.lib
*.o
*.obj
*.map
*.drc
*.tds
*.~*
*.tmp
*.bak

# Coverage output
tools/coverage/output/
*.coverage

# IDE caches
*.cfg
*.dof

# OS / editor
Thumbs.db
.DS_Store
*.swp
*~
.vscode/
.idea/

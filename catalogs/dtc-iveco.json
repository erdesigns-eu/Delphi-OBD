      "possible_causes": [
        "Sensor / actuator failure",
        "Wiring fault",
        "Module driver failure"
      ],
      "verified": false,
      "symptoms": [
        "MIL on",
        "Possible drivability impact"
      ],
      "repair_guidance": [
        "1) Confirm boost target vs actual via live data.",

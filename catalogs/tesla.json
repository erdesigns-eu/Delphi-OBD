    { "did": "0xD051", "name": "battery_pack_soc", "description": "HV pack state of charge (%)", "ecu_address": "0x782",
      "decoder": { "kind": "uint8", "scale": 0.392, "unit": "%" } },
    { "did": "0xD052", "name": "battery_pack_soh", "description": "HV pack state of health (%)", "ecu_address": "0x782",
      "decoder": { "kind": "uint8", "scale": 0.392, "unit": "%" } },
    { "did": "0xD060", "name": "charge_status", "description": "Charge port status enum", "ecu_address": "0x792",
      "decoder": { "kind": "enum", "size": 1, "values": {"0x00": "idle", "0x01": "charging", "0x02": "full", "0x03": "fault"} } }
  ],
  "routines": []

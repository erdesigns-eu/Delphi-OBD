{
  "$schema": "https://github.com/erdesigns-eu/Delphi-OBD/schema/catalog-v1.json",
  "version": 1,
  "manufacturer_key": "TESLA",
  "display_name": "Tesla, Inc.",
  "applicable_wmis": ["5YJ","LRW","XP7","7SA"],

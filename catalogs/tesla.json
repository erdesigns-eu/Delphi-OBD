    { "address": "0x7DF", "name": "gateway",       "common_name": "OBD-II broadcast (functional)" },
    { "address": "0x7E0", "name": "powertrain",    "common_name": "Powertrain Controller" },
    { "address": "0x7E1", "name": "gateway_p",     "common_name": "Vehicle Gateway" },
    { "address": "0x782", "name": "bms",           "common_name": "BMS — Battery Management" },
    { "address": "0x724", "name": "autopilot",     "common_name": "Autopilot ECU (HW3 / HW4)" },
    { "address": "0x762", "name": "driver_door",   "common_name": "Driver-side body controller" },
    { "address": "0x772", "name": "cabin",         "common_name": "Cabin / Touchscreen IHU" },
    { "address": "0x792", "name": "charging",      "common_name": "Charge Port Controller" }
  ],
  "dids": [
    { "did": "0xF1A0", "name": "tesla_firmware_version", "description": "Firmware version string (Tesla Toolbox)", "ecu_address": "0x7E1",
      "decoder": { "kind": "ascii" } },
    { "did": "0xF1A2", "name": "tesla_hardware_id", "description": "Tesla hardware platform (HW1/2.5/3/4)", "ecu_address": "0x724",
      "decoder": { "kind": "ascii" } },
    { "did": "0xD050", "name": "battery_pack_voltage", "description": "HV pack voltage (Tesla)", "ecu_address": "0x782",

{
  "$schema": "https://github.com/erdesigns-eu/Delphi-OBD/schema/catalog-v1.json",
  "version": 1,
  "manufacturer_key": "VAG",
  "display_name": "Volkswagen Audi Group",
  "applicable_wmis": ["WVW", "WV1", "WV2", "WAU", "TRU", "TMB", "VSS"],
  "default_source": "ross-tech-wiki / community",
  "dids": [
    { "did": "0xF1A0", "name": "vag_long_coding",            "description": "VAG long-coding string (per-controller bit-field)",          "source": "ross-tech-wiki", "verified": false, "decoder": { "kind": "hex" } },
    { "did": "0xF1A1", "name": "vag_workshop_code",          "description": "VAG WSC (workshop code, last writer)",                       "source": "ross-tech-wiki", "verified": false, "decoder": { "kind": "ascii" } },
    { "did": "0xF1A2", "name": "vag_dataset_number",         "description": "VAG dataset number (for ECU sub-variant)",                   "source": "community-pr", "verified": false, "decoder": { "kind": "ascii" } },
    { "did": "0xF1A3", "name": "vag_dataset_version",        "description": "VAG dataset version",                                        "source": "community-pr", "verified": false, "decoder": { "kind": "ascii" } },
    { "did": "0xF1A4", "name": "vag_engineering_part_number","description": "VAG engineering part number",                                "source": "community-pr", "verified": false, "decoder": { "kind": "ascii" } },
    { "did": "0xF1A5", "name": "vag_dataset_name",           "description": "VAG dataset friendly name",                                  "source": "community-pr", "verified": false, "decoder": { "kind": "ascii" } },
    { "did": "0xF1AD", "name": "vag_hardware_revision",      "description": "VAG hardware revision letter",                               "source": "community-pr", "verified": false, "decoder": { "kind": "ascii" } },
    { "did": "0xF1AF", "name": "vag_long_coding_extended",   "description": "VAG extended long coding (newer MQB ECUs)",                  "source": "obdeleven-public", "verified": false, "decoder": { "kind": "hex" } },

    { "did": "0xF40D", "name": "vehicle_speed",              "description": "Vehicle speed (km/h, 16-bit)",                               "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint16_be", "scale": 1, "unit": "km/h" } },
    { "did": "0xF405", "name": "battery_voltage",            "description": "Battery voltage in mV (16-bit)",                              "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint16_be", "scale": 0.001, "unit": "V" } },
    { "did": "0xF40C", "name": "engine_rpm",                 "description": "Engine RPM",                                                  "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint16_be", "scale": 0.25, "unit": "rpm" } },
    { "did": "0xF407", "name": "engine_coolant_temperature", "description": "Coolant temperature (°C, with -40 offset)",                  "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "offset": -40, "unit": "C" } },
    { "did": "0xF411", "name": "throttle_position",          "description": "Throttle position (%)",                                      "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "scale": 0.39215686, "unit": "%" } },
    { "did": "0xF40F", "name": "intake_air_temperature",     "description": "Intake air temperature (°C)",                                "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "offset": -40, "unit": "C" } },

    { "did": "0x0202", "name": "vag_mileage_short",          "description": "VAG mileage (3-byte big-endian, km)",                        "source": "obdeleven-public", "verified": false,
      "decoder": { "kind": "hex" } },
    { "did": "0x0223", "name": "vag_engine_oil_temperature", "description": "Engine oil temperature (°C)",                                "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "offset": -40, "unit": "C" } },
    { "did": "0x0224", "name": "vag_oil_level",              "description": "Oil level percent",                                          "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "scale": 0.39215686, "unit": "%" } },
    { "did": "0x0225", "name": "vag_fuel_level",             "description": "Fuel tank level percent",                                    "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "scale": 0.39215686, "unit": "%" } },
    { "did": "0x0226", "name": "vag_outside_air_temperature","description": "Outside air temperature (°C)",                                "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "offset": -40, "unit": "C" } },
    { "did": "0x0228", "name": "vag_clutch_pedal_status",    "description": "Clutch pedal pressed bitmask",                                "source": "community-pr", "verified": false,
      "decoder": { "kind": "hex" } },
    { "did": "0x0230", "name": "vag_kickdown_status",        "description": "Kickdown / brake status",                                    "source": "community-pr", "verified": false,
      "decoder": { "kind": "hex" } },
    { "did": "0x0260", "name": "vag_gear_position",          "description": "Current gear position",                                      "source": "community-pr", "verified": false,
      "decoder": { "kind": "uint8" } },
    { "did": "0x028B", "name": "vag_atf_temperature",        "description": "Automatic transmission fluid temperature (°C)",              "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "uint8", "offset": -50, "unit": "C" } },

    { "did": "0x0281", "name": "vag_steering_angle",         "description": "Steering wheel angle (signed, 16-bit, deg/10)",              "source": "ross-tech-wiki", "verified": false,
      "decoder": { "kind": "int16_be", "scale": 0.1, "unit": "deg" } },
    { "did": "0x0282", "name": "vag_yaw_rate",               "description": "Yaw rate (deg/s, signed)",                                   "source": "community-pr", "verified": false,
      "decoder": { "kind": "int16_be", "scale": 0.1, "unit": "deg/s" } },

    { "did": "0x06F1", "name": "vag_security_access_seed_l1","description": "Security access seed for level 1",                            "source": "community-pr", "verified": false,
      "decoder": { "kind": "hex" } },
    { "did": "0x06F2", "name": "vag_security_access_seed_l3","description": "Security access seed for level 3 (programming)",            "source": "community-pr", "verified": false,
      "decoder": { "kind": "hex" } }
  ],
  "routines": [
    { "id": "0x0203", "name": "reset_long_term_fuel_trim", "description": "Reset adaptive trims",            "source": "ross-tech-wiki",  "verified": false },
    { "id": "0x0301", "name": "basic_setting",             "description": "VAG basic setting routine",       "source": "ross-tech-wiki",  "verified": false },
    { "id": "0x0302", "name": "output_test",               "description": "VAG actuator / output test",      "source": "ross-tech-wiki",  "verified": false },
    { "id": "0x0F00", "name": "sas_calibration",           "description": "Steering-angle sensor reset",     "source": "community-pr",    "verified": false },
    { "id": "0x0F01", "name": "lwr_calibration",           "description": "Headlight range adjustment",      "source": "community-pr",    "verified": false },
    { "id": "0x0F03", "name": "vagcom_login",              "description": "VAG-COM login (legacy KWP2000)",  "source": "ross-tech-wiki",  "verified": false }
  ]
}

{
  "$schema": "https://github.com/erdesigns-eu/Delphi-OBD/schema/catalog-v1.json",
  "version": 1,
  "manufacturer_key": "UDS",
  "display_name": "ISO 14229-1 Universal UDS DIDs",
  "applicable_wmis": [],
  "default_source": "iso-14229-1:2020 Annex F (DataIdentifier table)",
  "dids": [
    { "did": "0xF180", "name": "boot_software_identification",                            "description": "Boot software identification block (manufacturer-defined ASCII)", "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF181", "name": "application_software_identification",                     "description": "Application software identification block",                     "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF182", "name": "application_data_identification",                         "description": "Application data identification block",                         "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF183", "name": "boot_software_fingerprint",                               "description": "Boot software fingerprint",                                       "verified": true,
      "decoder": { "kind": "hex" } },
    { "did": "0xF184", "name": "application_software_fingerprint",                        "description": "Application software fingerprint",                                "verified": true,
      "decoder": { "kind": "hex" } },
    { "did": "0xF185", "name": "application_data_fingerprint",                            "description": "Application data fingerprint",                                    "verified": true,
      "decoder": { "kind": "hex" } },
    { "did": "0xF186", "name": "active_diagnostic_session",                               "description": "Currently active UDS diagnostic session",                         "verified": true,
      "decoder": { "kind": "enum", "size": 1,
                   "values": { "0x01": "default", "0x02": "programming", "0x03": "extended", "0x04": "safety_system" } } },
    { "did": "0xF187", "name": "vehicle_manufacturer_spare_part_number",                  "description": "Manufacturer service part number (ASCII)",                        "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF188", "name": "vehicle_manufacturer_ecu_software_number",                "description": "Manufacturer ECU software number",                                "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF189", "name": "vehicle_manufacturer_ecu_software_version_number",        "description": "Manufacturer ECU software version",                               "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF18A", "name": "system_supplier_identifier",                              "description": "System supplier identifier",                                      "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF18B", "name": "ecu_manufacturing_date",                                  "description": "ECU manufacturing date (YYMMDD BCD)",                             "verified": true,
      "decoder": { "kind": "bcd_date" } },
    { "did": "0xF18C", "name": "ecu_serial_number",                                       "description": "ECU serial number",                                               "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF18D", "name": "supported_functional_units",                              "description": "Bit-mask of supported functional units",                          "verified": true,
      "decoder": { "kind": "hex" } },
    { "did": "0xF18E", "name": "vehicle_manufacturer_kit_assembly_part_number",           "description": "Manufacturer kit assembly part number",                           "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF190", "name": "vin",                                                     "description": "Vehicle identification number (17 chars ASCII)",                  "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF191", "name": "vehicle_manufacturer_ecu_hardware_number",                "description": "Manufacturer ECU hardware number",                                "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF192", "name": "system_supplier_ecu_hardware_number",                     "description": "Supplier ECU hardware number",                                    "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF193", "name": "system_supplier_ecu_hardware_version_number",             "description": "Supplier ECU hardware version",                                   "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF194", "name": "system_supplier_ecu_software_number",                     "description": "Supplier ECU software number",                                    "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF195", "name": "system_supplier_ecu_software_version_number",             "description": "Supplier ECU software version",                                   "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF196", "name": "exhaust_regulation_or_type_approval_number",              "description": "Exhaust regulation / type approval number",                       "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF197", "name": "system_name_or_engine_type",                              "description": "ECU long name / engine-type identifier",                          "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF198", "name": "repair_shop_code_or_tester_serial_number",                "description": "Repair shop / tester serial number (last write)",                 "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF199", "name": "programming_date",                                        "description": "Last programming date (YYMMDD BCD)",                              "verified": true,
      "decoder": { "kind": "bcd_date" } },
    { "did": "0xF19A", "name": "calibration_repair_shop_code_or_calibration_serial",      "description": "Calibration repair shop or calibration equipment serial",         "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF19B", "name": "calibration_date",                                        "description": "Last calibration date (YYMMDD BCD)",                              "verified": true,
      "decoder": { "kind": "bcd_date" } },
    { "did": "0xF19C", "name": "calibration_equipment_software_number",                   "description": "Calibration equipment software identifier",                       "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF19D", "name": "ecu_installation_date",                                   "description": "ECU installation date (YYMMDD BCD)",                              "verified": true,
      "decoder": { "kind": "bcd_date" } },
    { "did": "0xF19E", "name": "odx_file_data_identifier",                                "description": "ODX file identifier",                                             "verified": true,
      "decoder": { "kind": "ascii" } },
    { "did": "0xF19F", "name": "entity_data_identifier",                                  "description": "Entity data identifier (per ISO 14229-1 amendment)",               "verified": true,
      "decoder": { "kind": "ascii" } }
  ],
  "routines": [
    { "id": "0x0202", "name": "erase_memory_classic",       "description": "Erase memory routine (manufacturer-allocated)", "verified": false },
    { "id": "0xFF00", "name": "erase_memory",               "description": "ISO 14229-1 reserved erase routine",            "verified": true },
    { "id": "0xFF01", "name": "check_programming_dependencies", "description": "Cross-ECU dependency check (ISO 14229-1 reserved)", "verified": true },
    { "id": "0xFF02", "name": "verify_programming_checksum",   "description": "Post-flash checksum verification (ISO 14229-1 reserved)", "verified": true }
  ]
}

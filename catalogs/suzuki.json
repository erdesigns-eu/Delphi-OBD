{
  "$schema": "https://github.com/erdesigns-eu/Delphi-OBD/schema/catalog-v1.json",
  "version": 1,
  "manufacturer_key": "SUZUKI",
  "display_name": "Suzuki Motor Corp. (incl. Maruti Suzuki India)",
  "applicable_wmis": ["JS1","JS2","JSA","JSB","TSM","LSJ","MA3","MBH","ML8"],
  "default_source": "sdt-community",
  "ecus": [
    { "address": "0x7E0", "name": "engine",       "common_name": "Engine ECU (ECM)" },
    { "address": "0x7E1", "name": "transmission", "common_name": "TCM (incl. AGS / CVT)" },
    { "address": "0x7B0", "name": "abs",          "common_name": "ABS / ESP" },
    { "address": "0x7C0", "name": "srs",          "common_name": "SRS / Airbag" },
    { "address": "0x7C8", "name": "cluster",      "common_name": "Combination Meter" },
    { "address": "0x7E5", "name": "hvac",         "common_name": "Climate Control" },
    { "address": "0x7C4", "name": "body",         "common_name": "BCM" }
  ],
  "dids": [
    { "did": "0xF1A0", "name": "suzuki_chassis_code", "description": "Suzuki / Maruti chassis code", "ecu_address": "0x7C8",
      "decoder": { "kind": "ascii" } },
    { "did": "0xD050", "name": "vehicle_mileage", "description": "Vehicle mileage in km", "ecu_address": "0x7C8",
      "decoder": { "kind": "uint32_be", "unit": "km" } },
    { "did": "0xD051", "name": "battery_voltage", "description": "Battery voltage (mV)", "ecu_address": "0x7E0",
      "decoder": { "kind": "uint16_be", "scale": 0.001, "unit": "V" } },
    { "did": "0xD052", "name": "engine_coolant_temperature", "description": "Coolant temperature (°C)", "ecu_address": "0x7E0",
      "decoder": { "kind": "uint8", "offset": -40, "unit": "C" } }
  ],
  "routines": [
    { "id": "0x0204", "name": "idle_relearn", "description": "Idle-air-control relearn (SDT-II)", "ecu_address": "0x7E0" }
  ]
}

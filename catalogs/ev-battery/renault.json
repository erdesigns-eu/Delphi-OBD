  "phase1_fields": [
    { "field": "soc_p1",          "service_hex": "0x21", "did_hex": "0x01", "offset": 4, "length": 2, "scale": 0.025, "offset_value": 0, "unit": "%", "notes": "Phase 1 LBC, Mode 21 group 0x01.", "source": "https://github.com/openvehicles/Open-Vehicle-Monitoring-System-3/tree/master/vehicle/OVMS.V3/components/vehicle_renaultzoe" },
    { "field": "soh_p1",          "service_hex": "0x21", "did_hex": "0x61", "offset": 0, "length": 1, "scale": 1, "offset_value": 0, "unit": "%", "source": "https://github.com/openvehicles/Open-Vehicle-Monitoring-System-3/tree/master/vehicle/OVMS.V3/components/vehicle_renaultzoe" }

    { "field": "soh",             "service_hex": "0x22", "did_hex": "0x9002", "offset": 0, "length": 1, "scale": 1,     "offset_value": 0, "unit": "%",   "notes": "Phase 2; SOH is a single byte 0-100.", "source": "https://canze.fisch.lu/battery-health-status/" },
    { "field": "pack_voltage",    "service_hex": "0x22", "did_hex": "0x9005", "offset": 0, "length": 2, "scale": 0.5,   "offset_value": 0, "unit": "V",   "notes": "Phase 2 - confirmed by CanZE field DC volts.", "source": "https://canze.fisch.lu/" },
    { "field": "pack_current",    "service_hex": "0x22", "did_hex": "0x9006", "offset": 0, "length": 2, "scale": 0.0625,"offset_value": 0, "unit": "A", "signed": true, "source": "https://canze.fisch.lu/" },
    { "field": "min_cell_voltage","service_hex": "0x22", "did_hex": "0x9015", "offset": 0, "length": 2, "scale": 0.001, "offset_value": 0, "unit": "V",   "source": "https://canze.fisch.lu/" },
    { "field": "max_cell_voltage","service_hex": "0x22", "did_hex": "0x9016", "offset": 0, "length": 2, "scale": 0.001, "offset_value": 0, "unit": "V",   "source": "https://canze.fisch.lu/" },
    { "field": "min_pack_temp",   "service_hex": "0x22", "did_hex": "0x9018", "offset": 0, "length": 1, "scale": 1,     "offset_value": -40, "unit": "C", "source": "https://canze.fisch.lu/" },
    { "field": "max_pack_temp",   "service_hex": "0x22", "did_hex": "0x9017", "offset": 0, "length": 1, "scale": 1,     "offset_value": -40, "unit": "C", "source": "https://canze.fisch.lu/" }

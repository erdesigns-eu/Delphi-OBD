{
  "$schema": "../_schema/ev-battery.schema.json",
  "vendor": "renault",
  "label": "Renault Zoe (Phase 1 Q210/R240/Q90/R90 22-41 kWh; Phase 2 ZE50 R110/R135 52 kWh). Phase 1 uses Mode 21; Phase 2 uses 29-bit UDS Mode 22.",
  "ecu": {
    "request_id_hex": "0x792",

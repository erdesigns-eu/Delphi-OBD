  },
  "applicable_models": [
    "Renault Zoe Q210 (2013-2016)",
    "Renault Zoe R240 (2015-2017)",
    "Renault Zoe Q90 / R90 (2017-2019, 41 kWh)",
    "Renault Zoe ZE50 R110 / R135 (2019+, 52 kWh) - Phase 2"
  ],
  "fields": [

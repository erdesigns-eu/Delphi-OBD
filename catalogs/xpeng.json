    { "address": "0x712", "name": "motor_rear",   "common_name": "Rear Motor Inverter" },
    { "address": "0x782", "name": "bms",          "common_name": "BMS — Battery Management" },
    { "address": "0x792", "name": "charge",       "common_name": "Charge Port + AC/DC charger" },
    { "address": "0x720", "name": "cluster",      "common_name": "Instrument Cluster" },
    { "address": "0x724", "name": "xpilot",       "common_name": "XPILOT — Xpeng ADAS computer" },
    { "address": "0x762", "name": "bcm",          "common_name": "BCM" },
    { "address": "0x768", "name": "climate",      "common_name": "Climate Control / Heat Pump" },
    { "address": "0x770", "name": "xui",          "common_name": "Xmart OS — Cabin computer" }

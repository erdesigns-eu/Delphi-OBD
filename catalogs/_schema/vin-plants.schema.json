{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erdesigns.eu/delphi-obd/schemas/vin-plants.schema.json",
  "title": "VIN plant locations",
  "description": "Per-WMI plant code lookup. The 'key' is a 4-character composite of WMI (3) + plant character (1).",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "spec":           { "type": "string" },
    "description":    { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "code", "name"],
        "properties": {
          "key":     { "type": "string", "minLength": 4, "maxLength": 4 },
          "code":    { "type": "string", "minLength": 1, "maxLength": 1 },
          "name":    { "type": "string", "minLength": 1 },
          "city":    { "type": "string" },
          "country": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

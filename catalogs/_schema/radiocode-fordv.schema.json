{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erdesigns.eu/delphi-obd/schemas/radiocode-fordv.schema.json",
  "title": "Ford V-series radio-code lookup",
  "description": "Ford V-series 4-digit code lookup. Index = serial (0..999998); value = code string.",
  "type": "object",
  "required": ["schema_version", "format", "count", "codes"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "brand":          { "type": "string" },
    "format":         { "type": "string", "const": "V-series" },
    "description":    { "type": "string" },
    "count":          { "type": "integer", "const": 999999 },
    "codes": {
      "type": "array",
      "minItems": 999999,
      "maxItems": 999999,
      "items": { "type": "string", "minLength": 4, "maxLength": 4 }
    }
  },
  "additionalProperties": false
}

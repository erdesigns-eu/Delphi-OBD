    { "code": "P0455", "severity": "info",     "description": "Evaporative Emission Control System Leak (Large Leak)", "verified": true },
    { "code": "P0500", "severity": "warning",  "description": "Vehicle Speed Sensor Malfunction", "verified": true },
    { "code": "P0505", "severity": "warning",  "description": "Idle Air Control System Malfunction", "verified": true },
